# For local development, use the Railway Postgres public connection string and
# append ?sslmode=require if it is not already present.
DATABASE_URL="postgresql://postgres:password@your-proxy-host:5432/railway?sslmode=require"

# Optional: use a separate URL for Drizzle CLI commands.
DRIZZLE_DATABASE_URL="postgresql://postgres:password@your-proxy-host:5432/railway?sslmode=require"
