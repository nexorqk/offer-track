# Default local development database.
# Assumes your Ubuntu PostgreSQL service is already running locally.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/offer_track?sslmode=disable"

# Optional: keep Drizzle pointed at the same local database.
DRIZZLE_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/offer_track?sslmode=disable"
